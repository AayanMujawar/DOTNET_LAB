@model IEnumerable<MyApp.MVCApp.Models.Customer>

<!-- Admin Dashboard Theme -->
<div class="row mt-4">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0">⚙️ Dashboard: Manage Registered Customers</h4>
                <a asp-action="Create" class="btn btn-warning fw-bold">+ Add New Customer</a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th># ID</th>
                                <th>Name</th>
                                <th>Contact Email</th>
                                <th>Age</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted">No customers found. Click 'Add New Customer' to register one.</td>
                                </tr>
                            }
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">@item.Id</span></td>
                                    <td class="fw-bold">@item.Name</td>
                                    <td><a href="mailto:@item.Email">@item.Email</a></td>
                                    <td>@item.Age</td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm me-2">✏️ Edit</a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm" onclick="return confirm('Are you sure you want to delete this customer?');">🗑 Delete</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow border-0">
            <div class="card-body p-5">
                <h3 class="text-center mb-4">🔐 Login to TechStore</h3>
                
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form asp-action="Login" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Email Address</label>
                        <input type="email" name="email" class="form-control" required placeholder="customer@techstore.com or admin@techstore.com" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Password</label>
                        <input type="password" name="password" class="form-control" required placeholder="customer or admin" />
                    </div>
                    <button type="submit" class="btn btn-warning w-100 fw-bold">Sign In</button>
                </form>

                <hr class="my-4" />
                <div class="text-center text-muted small">
                    <p><strong>Demo Credentials:</strong></p>
                    <p>Admin: admin@techstore.com / admin</p>
                    <p>Customer: customer@techstore.com / customer</p>
                </div>
            </div>
        </div>
    </div>
</div>
